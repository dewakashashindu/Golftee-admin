## Example environment for backend (do NOT commit secrets)
# Copy this to `.env` and fill secrets when needed.
PORT=4000
# For local SQLite development (default)
DATABASE_URL="file:./dev.db"
JWT_SECRET="replace-with-secure-secret"

# Optional: Supabase (only enable if you intend to use Supabase features)
# USE_SUPABASE=false
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
PORT=4000
# Add real secrets here in production
# DATABASE_URL=postgres://user:pass@localhost:5432/golftee

# Supabase (server-side)
# Set these locally, do NOT commit service role key to public repositories
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
 
# Example environment variables for backend
# Copy this file to `backend/.env` and update values for local development.

# Use SQLite for local development with Prisma (recommended for quick setup):
# DATABASE_URL="file:./dev.db"

# JWT secret used to sign tokens when Prisma is used (keep secret in production)
# JWT_SECRET="change-this-to-a-strong-secret"

# If you use Supabase for auth/storage, set the SUPABASE_* entries above.


